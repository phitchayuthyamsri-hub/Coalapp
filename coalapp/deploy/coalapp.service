[Unit]
Description=Coal GPS Report (gunicorn)
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/opt/coalapp
Environment="SECRET_KEY=PUT-A-LONG-RANDOM-STRING-HERE"
ExecStart=/opt/coalapp/venv/bin/gunicorn -w 3 -b 127.0.0.1:8000 wsgi:app
Restart=always

[Install]
WantedBy=multi-user.target
